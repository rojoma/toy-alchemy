# ────────────────────────────────────────────────────────────
# Required — Training Field (training_field/web/app.py)
# ────────────────────────────────────────────────────────────

# OpenAI API key — required even if you mostly use Gemini, because
# vision (image scope extraction) still goes through OpenAI.
OPENAI_API_KEY=sk-...

# API key that external agents must send as `X-Field-Key` to hit /api/agent/*.
# Pick any strong random string; share out-of-band with clients.
FIELD_API_KEY=your_field_api_key_here


# ────────────────────────────────────────────────────────────
# LLM provider routing (per-role model selection)
# ────────────────────────────────────────────────────────────
# Each value is "provider:model_id". Provider must be one of:
#   - openai  (uses OPENAI_API_KEY)
#   - gemini  (uses GOOGLE_API_KEY)
# If unset, the role falls back to LLM_MODEL_DEFAULT, then to openai:gpt-4o.

# Fallback for any role without its own override:
# LLM_MODEL_DEFAULT=openai:gpt-4o

# Per-role overrides — uncomment to swap a single role.
# Math sessions are expensive on GPT-4o; Gemini works well as a cheaper teacher.
# LLM_MODEL_TEACHER=gemini:gemini-3-pro
# LLM_MODEL_STUDENT=openai:gpt-4o
# LLM_MODEL_REFEREE=openai:gpt-4o
# LLM_MODEL_JUDGE=openai:gpt-4o
# LLM_MODEL_QUESTION_BANK=openai:gpt-4o
# LLM_MODEL_TRANSLATOR=openai:gpt-4o

# Required only if any role uses gemini:*
# Get one at https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=

# Vision (image scope extraction) — OpenAI only for now.
# VISION_MODEL=gpt-4o


# ────────────────────────────────────────────────────────────
# Optional — LINE Bot front-end (src/line_bot_server.py)
# Development is currently paused; set these only if you're running the bot.
# ────────────────────────────────────────────────────────────
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
