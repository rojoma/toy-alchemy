{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Toy Alchemy - 子供学習プロファイル v2",
  "description": "Agent Pool + Explain-to-Learn対応。ペルソナ効果とフェーズ状態を記録。",
  "type": "object",
  "required": ["child_id"],
  "properties": {
    "child_id": {
      "type": "string",
      "description": "一意の識別子（LINE ユーザーID等）"
    },
    "display_name": {
      "type": "string",
      "description": "子供の表示名"
    },
    "grade": {
      "type": ["string", "null"],
      "description": "学年（例: '小学3年生'）"
    },
    "age": {
      "type": ["integer", "null"],
      "minimum": 4,
      "maximum": 18
    },
    "learning_preferences": {
      "type": "array",
      "description": "子供が好む学習アプローチ。ペルソナ選択の参考にする。",
      "items": { "type": "string" },
      "examples": [
        ["ゲームの例えが好き", "RPGっぽくすると集中する"],
        ["図を使った説明が好き", "ピザに例えると理解しやすい"],
        ["論理的な手順が好き", "パズルとして考えるのが得意"]
      ]
    },
    "persona_effectiveness": {
      "type": "object",
      "description": "各ペルソナの効果スコア。正の値=効果的、負の値=効果なし。ペルソナ選択のフィードバックに使用。",
      "properties": {
        "standard": { "type": "integer", "default": 0 },
        "gamemaster": { "type": "integer", "default": 0 },
        "artist": { "type": "integer", "default": 0 },
        "logic": { "type": "integer", "default": 0 }
      }
    },
    "error_patterns": {
      "type": "array",
      "description": "過去の間違え方のクセ・つまずきパターン",
      "items": {
        "type": "object",
        "required": ["subject", "description"],
        "properties": {
          "subject": { "type": "string" },
          "topic": { "type": "string" },
          "description": { "type": "string" },
          "frequency": {
            "type": "string",
            "enum": ["once", "occasional", "frequent"]
          },
          "last_seen": { "type": "string", "format": "date" },
          "resolved": { "type": "boolean", "default": false }
        }
      }
    },
    "strengths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "emotional_notes": {
      "type": "object",
      "properties": {
        "sensitivity_level": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "default": "medium"
        },
        "motivation_triggers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "frustration_signs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "session_history": {
      "type": "array",
      "description": "直近のセッション履歴（最新20件を保持推奨）",
      "items": {
        "type": "object",
        "required": ["session_id", "timestamp"],
        "properties": {
          "session_id": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "subject": { "type": "string" },
          "topic": { "type": "string" },
          "outcome": {
            "type": "string",
            "enum": ["understood", "partial", "struggled", "gave_up"]
          },
          "turns": { "type": "integer", "minimum": 1 },
          "current_phase": {
            "type": "string",
            "enum": ["questioning", "explaining", "resolved"],
            "description": "セッション終了時のフェーズ（Explain-to-Learnの状態）"
          },
          "tutor_persona_used": {
            "type": "string",
            "enum": ["standard", "gamemaster", "artist", "logic"],
            "description": "セッションで主に使われたTutorペルソナ"
          },
          "persona_switches": {
            "type": "array",
            "description": "セッション中のペルソナ切り替え履歴",
            "items": {
              "type": "object",
              "properties": {
                "from": { "type": "string" },
                "to": { "type": "string" },
                "reason": { "type": "string" },
                "turn": { "type": "integer" }
              }
            }
          },
          "explain_to_learn_attempts": {
            "type": "integer",
            "description": "子供が自己説明を試みた回数",
            "minimum": 0
          },
          "explanation_quality_score": {
            "type": "number",
            "description": "子供の説明の質スコア（0-5）。Refereeが評価。",
            "minimum": 0,
            "maximum": 5
          },
          "approach_used": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    },
    "parent_settings": {
      "type": "object",
      "properties": {
        "focus_subjects": { "type": "array", "items": { "type": "string" } },
        "session_time_limit_minutes": { "type": "integer", "default": 30 },
        "difficulty_preference": {
          "type": "string",
          "enum": ["easier", "grade_level", "challenging"],
          "default": "grade_level"
        },
        "preferred_persona": {
          "type": ["string", "null"],
          "enum": ["standard", "gamemaster", "artist", "logic", null],
          "description": "保護者が指定するペルソナ（nullなら自動選択）"
        },
        "notification_email": { "type": "string", "format": "email" }
      }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
