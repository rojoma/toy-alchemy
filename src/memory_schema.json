{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Toy Alchemy - 子供学習プロファイル",
  "description": "LINE Botユーザーごとの学習状態・特性を管理するスキーマ。CrewAIセッションに注入して個別最適化を実現する。",
  "type": "object",
  "required": ["child_id"],
  "properties": {
    "child_id": {
      "type": "string",
      "description": "一意の識別子（LINE ユーザーID等）"
    },
    "display_name": {
      "type": "string",
      "description": "子供の表示名（フクロウ先生が呼びかけに使う）"
    },
    "grade": {
      "type": ["string", "null"],
      "description": "学年（例: '小学3年生'）",
      "examples": ["小学1年生", "小学4年生", "中学1年生"]
    },
    "age": {
      "type": ["integer", "null"],
      "description": "年齢（学年から推定も可）",
      "minimum": 4,
      "maximum": 18
    },
    "learning_preferences": {
      "type": "array",
      "description": "子供が好む・効果的な学習アプローチのリスト",
      "items": {
        "type": "string"
      },
      "examples": [
        ["ゲームの例えが好き", "図を使った説明が好き"],
        ["ストーリー仕立てが好き", "手を動かして確かめたい"],
        ["クイズ形式が好き", "動物に例えると理解しやすい"]
      ]
    },
    "error_patterns": {
      "type": "array",
      "description": "過去の間違え方のクセ・つまずきパターン",
      "items": {
        "type": "object",
        "required": ["subject", "description"],
        "properties": {
          "subject": {
            "type": "string",
            "description": "教科・分野",
            "examples": ["算数", "国語", "理科", "社会", "英語"]
          },
          "topic": {
            "type": "string",
            "description": "具体的な単元名",
            "examples": ["繰り上がりのある足し算", "分数の通分", "漢字の部首"]
          },
          "description": {
            "type": "string",
            "description": "間違え方の具体的な説明"
          },
          "frequency": {
            "type": "string",
            "enum": ["once", "occasional", "frequent"],
            "description": "発生頻度（once=1回だけ, occasional=時々, frequent=頻繁）"
          },
          "last_seen": {
            "type": "string",
            "format": "date",
            "description": "最後に確認された日付（ISO 8601）"
          },
          "resolved": {
            "type": "boolean",
            "default": false,
            "description": "この間違いパターンが克服されたかどうか"
          }
        }
      }
    },
    "strengths": {
      "type": "array",
      "description": "得意なこと・褒めポイント",
      "items": {
        "type": "string"
      },
      "examples": [
        ["かけ算九九は完璧", "図形の名前をよく覚えている"],
        ["読解力が高い", "実験の観察が丁寧"]
      ]
    },
    "emotional_notes": {
      "type": "object",
      "description": "感情面・モチベーションに関する特記事項",
      "properties": {
        "sensitivity_level": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "default": "medium",
          "description": "間違いに対する感受性（highなら特に優しく励ます）"
        },
        "motivation_triggers": {
          "type": "array",
          "items": { "type": "string" },
          "description": "やる気が出るきっかけ",
          "examples": [["ポイントが貯まる", "キャラが褒めてくれる", "タイムアタック"]]
        },
        "frustration_signs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "イライラ・諦めのサイン（検知したらペースを緩める）",
          "examples": [["『もういい』と言う", "返答が極端に短くなる", "同じ答えを繰り返す"]]
        }
      }
    },
    "session_history": {
      "type": "array",
      "description": "直近のセッション履歴（最新20件を保持推奨）",
      "items": {
        "type": "object",
        "required": ["session_id", "timestamp"],
        "properties": {
          "session_id": {
            "type": "string",
            "description": "セッション識別子"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "セッション開始日時（ISO 8601）"
          },
          "subject": {
            "type": "string",
            "description": "教科"
          },
          "topic": {
            "type": "string",
            "description": "取り組んだ単元・問題"
          },
          "outcome": {
            "type": "string",
            "enum": ["understood", "partial", "struggled", "gave_up"],
            "description": "理解度（understood=理解, partial=部分的, struggled=苦戦, gave_up=諦めた）"
          },
          "approach_used": {
            "type": "string",
            "description": "効果的だった教授法",
            "examples": ["お菓子に例えた", "図を描いて説明", "クイズ形式"]
          },
          "turns": {
            "type": "integer",
            "description": "やり取りの往復回数",
            "minimum": 1
          },
          "notes": {
            "type": "string",
            "description": "セッションの特記事項"
          }
        }
      }
    },
    "parent_settings": {
      "type": "object",
      "description": "保護者の設定・要望",
      "properties": {
        "focus_subjects": {
          "type": "array",
          "items": { "type": "string" },
          "description": "重点的に取り組みたい教科"
        },
        "session_time_limit_minutes": {
          "type": "integer",
          "description": "1セッションの時間制限（分）",
          "default": 30,
          "minimum": 5,
          "maximum": 120
        },
        "difficulty_preference": {
          "type": "string",
          "enum": ["easier", "grade_level", "challenging"],
          "default": "grade_level",
          "description": "難易度設定"
        },
        "notification_email": {
          "type": "string",
          "format": "email",
          "description": "学習レポート送信先メールアドレス"
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "プロファイル作成日時"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "プロファイル最終更新日時"
    }
  }
}
