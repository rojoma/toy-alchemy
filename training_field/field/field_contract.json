                                                     "example_violation":  "The answer is 24.",
                                                     "example_compliant":  "What happens if you group these 24 items into sets of 6?"
                                                 },
                           "age_appropriate_language":  {
                                                            "rule":  "All output must suit a 12-15 year old comprehension level",
                                                            "readability_target":  "Grade 4-8 Japanese or English"
                                                        },
                           "turn_budget":  {
                                               "quick":  8,
                                               "standard":  12,
                                               "deep":  16,
                                               "rule":  "Complete all 4 phases within the allocated turn count"
                                           },
                           "log_format_compliance":  {
                                                         "rule":  "Every teacher response must return structured JSON metadata alongside text"
                                                     },
                           "frustration_threshold":  {
                                                         "rule":  "If student frustration_score exceeds 0.85, switch to encouragement mode immediately",
                                                         "threshold":  0.85
                                                     },
                           "safety":  {
                                          "rule":  "No content that could distress a child. Halt session and log if triggered."
                                      }
                       },
