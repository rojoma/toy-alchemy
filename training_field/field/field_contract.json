                                                         "Hattie_Visible_Learning"
                                                     ],
                              "human_validation":  {
                                                       "frequency":  "every_20_sessions",
                                                       "metric":  "cohen_kappa_target_0.7"
                                                   }
                          },
    "skills_library":  {
                           "location":  "training_field/field/skills/",
